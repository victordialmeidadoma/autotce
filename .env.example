# .env.example
# Copie para .env.local e preencha seus valores

# ============================================================================
# SUPABASE (Banco de Dados Gratuito)
# https://supabase.com
# ============================================================================

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-supabase-publica

# ============================================================================
# AMBIENTE
# ============================================================================

AMBIENTE=production

# ============================================================================
# COMO OBTER AS CHAVES:
# ============================================================================

"""
1. Criar conta em https://supabase.com (gratuito)
2. Criar novo projeto
3. Ir em Settings → API
4. Copiar a URL do projeto (SUPABASE_URL)
5. Copiar a chave pública (SUPABASE_KEY)
6. Colar aqui e em vercel.com (Project Settings → Environment Variables)
"""
